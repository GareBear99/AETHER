{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AETHER Preset Bank",
  "type": "object",
  "required": [
    "bankName",
    "presets"
  ],
  "properties": {
    "bankName": {
      "type": "string"
    },
    "presets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "values"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "values": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}