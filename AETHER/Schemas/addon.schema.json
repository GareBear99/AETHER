{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AETHER Addon Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "author",
    "version",
    "aetherMinVersion",
    "type",
    "description"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "aetherMinVersion": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "const": "panel-theme"
    },
    "priceHint": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "fallbackTheme": {
      "type": "string",
      "default": "Default"
    },
    "officialStatus": {
      "type": "string",
      "enum": [
        "official",
        "community",
        "unofficial"
      ],
      "default": "community"
    }
  },
  "additionalProperties": false
}